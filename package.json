{
  "name": "ecommerce",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "db:generate": "turbo run db:generate --filter=@repo/db",
    "db:push": "turbo run db:push --filter=@repo/db",
    "db:migrate": "turbo run db:migrate --filter=@repo/db"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "turbo": "latest"
  },
  "packageManager": "pnpm@9.5.0"
}